<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(CoreTargetFrameworks);net8.0-windows10.0.19041.0;net9.0-windows10.0.19041.0;net10.0-windows10.0.19041.0;net11.0-windows10.0.19041.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>CP.TwinCATRx.Reactive</PackageId>
    <Title>TwinCATRx.Reactive</Title>
    <RootNamespace>IoT.DriverCore.TwinCATRx.Reactive</RootNamespace>
    <DefineConstants>$(DefineConstants);REACTIVE_SHIM</DefineConstants>
    <TwinCATGeneratorAssemblyPath>..\TwinCATRx.Generators\bin\$(Configuration)\netstandard2.0\TwinCATRx.Generators.dll</TwinCATGeneratorAssemblyPath>
    <TwinCATGeneratorAssemblyPath Condition="'$(UseArtifactsOutput)' == 'true'">$(ArtifactsPath)\bin\TwinCATRx.Generators\$([System.String]::Copy('$(Configuration)').ToLowerInvariant())\TwinCATRx.Generators.dll</TwinCATGeneratorAssemblyPath>
  </PropertyGroup>

  <PropertyGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net8.0'))">
    <IsTrimmable>true</IsTrimmable>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnableAotAnalyzer>true</EnableAotAnalyzer>
    <DefineConstants>$(DefineConstants);HASHTABLERX_STRUCTURE_API</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="$([System.String]::new('$(TargetFramework)').StartsWith('net4')) or '$(TargetFramework)' == 'net8.0-windows10.0.19041.0' or '$(TargetFramework)' == 'net9.0-windows10.0.19041.0' or '$(TargetFramework)' == 'net10.0-windows10.0.19041.0' or '$(TargetFramework)' == 'net11.0-windows10.0.19041.0'">
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
  </PropertyGroup>

  <ItemGroup Condition="$([System.String]::new('$(TargetFramework)').StartsWith('net4'))">
    <PackageReference Include="Polyfill" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\TwinCATRx\**\*.cs"
             Exclude="..\TwinCATRx\bin\**;..\TwinCATRx\obj\**"
             Link="%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="HashTableRx.Reactive" />
    <PackageReference Include="ReactiveUI.Primitives.Reactive" />
    <PackageReference Include="ReactiveUI.Primitives.Async.Reactive" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TwinCATRx.Core.Reactive\TwinCATRx.Core.Reactive.csproj" />
    <ProjectReference Include="..\TwinCATRx.Generators\TwinCATRx.Generators.csproj" ReferenceOutputAssembly="false" PrivateAssets="all" />
    <ProjectReference Include="..\CP.IoT.Core\CP.IoT.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="ReactiveUI.Primitives" />
    <Using Include="ReactiveUI.Primitives.Reactive" />
    <Using Include="ReactiveUI.Primitives.Async" />
    <Using Include="ReactiveUI.Primitives.Async.Reactive" />
    <Using Include="ReactiveUI.Primitives.Signals" />
    <Using Include="ReactiveUI.Primitives.Reactive.Signals" />
    <Using Include="ReactiveUI.Primitives.Disposables.MultipleDisposable" Alias="CompositeDisposable" />
    <Using Include="ReactiveUI.Primitives.Reactive.Signals.Signal" Alias="Observable" />
    <Using Include="System.Reactive.Unit" Alias="Unit" />
  </ItemGroup>

  <ItemGroup>
    <None Include="$(TwinCATGeneratorAssemblyPath)"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false"
          Condition="Exists('$(TwinCATGeneratorAssemblyPath)')" />
  </ItemGroup>

  <Import Project="..\CP.IoT.Core\buildTransitive\CP.IoT.Core.targets"
          Condition="Exists('..\CP.IoT.Core\buildTransitive\CP.IoT.Core.targets')" />

</Project>
